#ifndef GLOBALS_H
#define GLOBALS_H

#include <chrono>
#include <fstream>
#include <pthread.h>
#include <semaphore.h>

// Match-wide shared state. Every player thread reads and/or writes this state,
// so updates must be guarded by the appropriate synchronization primitives.
struct MatchContext {
    int global_score;
    int total_wickets;
    int current_over;
    int balls_in_current_over;
};

constexpr int TEAM_SIZE = 11;
constexpr int BOWLER_POOL_SIZE = 5;
constexpr int INVALID_HIT_RESULT = -999;

// Logical player role in the simulator.
enum class PlayerRole {
    BOWLER,
    BATSMAN,
    FIELDER,
    WICKETKEEPER
};

// Per-thread control block. This mirrors the idea of an operating-system PCB:
// identity, role, and runtime state needed by the scheduler/simulation engine.
struct PlayerControlBlock {
    int player_id;
    pthread_t thread_id;
    PlayerRole role;
    bool is_active_on_pitch;
    bool is_waiting_in_pavilion;
    int expected_stay_duration;
    int deliveries_bowled;
    int last_ball_faced;
    double arrival_time;
    double dispatch_time;
    int priority_score;
    bool is_death_over_specialist;
};

// Global match state instance.
extern MatchContext g_match_context;

// Logical identifier of the batsman thread currently allowed to face delivery.
extern int active_striker_id;
extern int non_striker_id;
extern bool match_completed;

// True when a struck ball is in play and fielders should wake up.
extern bool ball_in_air;

// Alias-style flag used by entity routines for readability.
extern bool is_ball_in_air;

// Number of currently active batsmen at the crease.
extern int active_batsmen_count;

// Shared fielding outcome communicated back to the striker.
extern int shared_hit_result;

// Sequence guards to ensure exactly one fielder resolves each struck ball.
extern int current_ball_sequence;
extern int handled_ball_sequence;

// Shared guard so only one bowler announces each global delivery number.
extern int last_announced_delivery;

// Resource-allocation graph wait edges for deadlock detection.
extern volatile pthread_t waiting_for_end1;
extern volatile pthread_t waiting_for_end2;

// Tracked lock owners for run-end mutexes.
extern pthread_t end1_owner;
extern pthread_t end2_owner;

// Pointers to currently active batsmen.
extern PlayerControlBlock* active_striker_pcb;
extern PlayerControlBlock* active_non_striker_pcb;

// SJF pavilion queue for incoming batsmen.
extern PlayerControlBlock* pavilion_queue[TEAM_SIZE];
extern int pavilion_size;

// Round-robin bowler pool and active index.
extern PlayerControlBlock* bowler_pool[BOWLER_POOL_SIZE];
extern int bowler_pool_size;
extern int current_bowler_index;
extern PlayerControlBlock* current_bowler_pcb;

// Control flags for inter-batsman run exchange simulation.
extern bool run_exchange_requested;
extern bool force_deadlock_exchange;
extern bool keeper_event_pending;
extern bool over_change_requested;
extern bool use_sjf_scheduling;
extern bool match_intensity_high;
extern bool use_priority_scheduling;

// Protects scoring-related critical sections (atomic score updates).
extern pthread_mutex_t score_mutex;

// Represent the two ends of the pitch. These are independent resources that
// can be locked in different orders during run attempts to model contention.
extern pthread_mutex_t end1_mutex;
extern pthread_mutex_t end2_mutex;

// Protects the ball retrieval race among fielders.
extern pthread_mutex_t ball_mutex;

// Serializes stdout/stderr logs so concurrent prints do not interleave.
extern pthread_mutex_t log_mutex;

// Serializes writes to the Gantt CSV output file.
extern pthread_mutex_t file_mutex;

// Coordination primitives for waking fielders.
extern pthread_cond_t fielders_cond;
extern pthread_cond_t keeper_cond;
extern pthread_cond_t umpire_cond;
extern pthread_cond_t batsman_cond;
extern pthread_cond_t run_exchange_cond;
extern pthread_cond_t bowler_manager_cond;

// Limits crease occupancy to two active batsmen.
extern sem_t crease_semaphore;

// Simulation clock and structured Gantt output stream.
extern std::chrono::high_resolution_clock::time_point simulation_start_time;
extern std::ofstream gantt_log_file;
extern std::ofstream wait_time_log_file;

double get_timestamp();

#endif  // GLOBALS_H
