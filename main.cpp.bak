#include "entities.h"
#include "globals.h"

#include <algorithm>
#include <cerrno>
#include <chrono>
#include <cstdio>
#include <cstdlib>
#include <unordered_set>

namespace {

bool InitMutex(pthread_mutex_t* mutex, const char* resource_name) {
    const int rc = pthread_mutex_init(mutex, nullptr);
    if (rc != 0) {
        errno = rc;
        perror(resource_name);
        return false;
    }
    return true;
}

bool InitCondVar(pthread_cond_t* cond_var, const char* resource_name) {
    const int rc = pthread_cond_init(cond_var, nullptr);
    if (rc != 0) {
        errno = rc;
        perror(resource_name);
        return false;
    }
    return true;
}

void SortPavilionBySJF() {
    std::sort(pavilion_queue, pavilion_queue + pavilion_size,
              [](const PlayerControlBlock* a, const PlayerControlBlock* b) {
                  if (a == nullptr || b == nullptr) {
                      return false;
                  }
                  return a->expected_stay_duration < b->expected_stay_duration;
              });
}

}  // namespace

int main() {
    PlayerControlBlock* fielding_team[TEAM_SIZE] = {nullptr};
    PlayerControlBlock* batting_team[TEAM_SIZE] = {nullptr};
    pthread_t umpire_thread = static_cast<pthread_t>(0);
    pthread_t bowler_manager_thread = static_cast<pthread_t>(0);
    const char* wait_time_filename = "wait_times_sjf.csv";

    bool score_mutex_ready = false;
    bool end1_mutex_ready = false;
    bool end2_mutex_ready = false;
    bool ball_mutex_ready = false;
    bool log_mutex_ready = false;
    bool file_mutex_ready = false;
    bool fielders_cond_ready = false;
    bool keeper_cond_ready = false;
    bool umpire_cond_ready = false;
    bool batsman_cond_ready = false;
    bool run_exchange_cond_ready = false;
    bool bowler_manager_cond_ready = false;
    bool crease_semaphore_ready = false;

    if (!InitMutex(&score_mutex, "pthread_mutex_init(score_mutex) failed")) {
        return EXIT_FAILURE;
    }
    score_mutex_ready = true;

    if (!InitMutex(&end1_mutex, "pthread_mutex_init(end1_mutex) failed")) {
        goto cleanup;
    }
    end1_mutex_ready = true;

    if (!InitMutex(&end2_mutex, "pthread_mutex_init(end2_mutex) failed")) {
        goto cleanup;
    }
    end2_mutex_ready = true;

    if (!InitMutex(&ball_mutex, "pthread_mutex_init(ball_mutex) failed")) {
        goto cleanup;
    }
    ball_mutex_ready = true;

    if (!InitMutex(&log_mutex, "pthread_mutex_init(log_mutex) failed")) {
        goto cleanup;
    }
    log_mutex_ready = true;

    if (!InitMutex(&file_mutex, "pthread_mutex_init(file_mutex) failed")) {
        goto cleanup;
    }
    file_mutex_ready = true;

    if (!InitCondVar(&fielders_cond, "pthread_cond_init(fielders_cond) failed")) {
        goto cleanup;
    }
    fielders_cond_ready = true;

    if (!InitCondVar(&keeper_cond, "pthread_cond_init(keeper_cond) failed")) {
        goto cleanup;
    }
    keeper_cond_ready = true;

    if (!InitCondVar(&umpire_cond, "pthread_cond_init(umpire_cond) failed")) {
        goto cleanup;
    }
    umpire_cond_ready = true;

    if (!InitCondVar(&batsman_cond, "pthread_cond_init(batsman_cond) failed")) {
        goto cleanup;
    }
    batsman_cond_ready = true;

    if (!InitCondVar(&run_exchange_cond, "pthread_cond_init(run_exchange_cond) failed")) {
        goto cleanup;
    }
    run_exchange_cond_ready = true;

    if (!InitCondVar(&bowler_manager_cond, "pthread_cond_init(bowler_manager_cond) failed")) {
        goto cleanup;
    }
    bowler_manager_cond_ready = true;

    if (sem_init(&crease_semaphore, 0, 2) != 0) {
        perror("sem_init(crease_semaphore) failed");
        goto cleanup;
    }
    crease_semaphore_ready = true;

    // Toggle these configuration flags and rerun to produce comparative datasets.
    // For wait-time analysis, run once with SJF=true and once with SJF=false.
    use_sjf_scheduling = true;
    use_priority_scheduling = true;

    simulation_start_time = std::chrono::high_resolution_clock::now();

    gantt_log_file.open("gantt_chart.csv", std::ios::out | std::ios::trunc);
    if (!gantt_log_file.is_open()) {
        perror("open(gantt_chart.csv) failed");
        goto cleanup;
    }
    gantt_log_file << "Timestamp,ThreadID,Role,Action,Resource\n";
    gantt_log_file.flush();

    wait_time_filename = use_sjf_scheduling ? "wait_times_sjf.csv" : "wait_times_fcfs.csv";
    wait_time_log_file.open(wait_time_filename, std::ios::out | std::ios::trunc);
    if (!wait_time_log_file.is_open()) {
        perror("open(wait_times_*.csv) failed");
        goto cleanup;
    }
    wait_time_log_file << "Algorithm,ThreadID,Role,ExpectedDuration,WaitTimeMs,RosterIndex,IsMiddleOrder\n";
    wait_time_log_file.flush();

    g_match_context = {0, 0, 0, 0};
    active_striker_id = -1;
    non_striker_id = -1;
    active_batsmen_count = 0;
    shared_hit_result = INVALID_HIT_RESULT;
    current_ball_sequence = 0;
    handled_ball_sequence = -1;
    last_announced_delivery = -1;
    match_completed = false;
    match_intensity_high = false;
    ball_in_air = false;
    is_ball_in_air = false;
    keeper_event_pending = false;
    run_exchange_requested = false;
    force_deadlock_exchange = false;
    over_change_requested = false;
    waiting_for_end1 = static_cast<pthread_t>(0);
    waiting_for_end2 = static_cast<pthread_t>(0);
    end1_owner = static_cast<pthread_t>(0);
    end2_owner = static_cast<pthread_t>(0);
    pavilion_size = 0;
    active_striker_pcb = nullptr;
    active_non_striker_pcb = nullptr;
    bowler_pool_size = 0;
    current_bowler_index = 0;
    current_bowler_pcb = nullptr;

    for (int i = 0; i < TEAM_SIZE; ++i) {
        fielding_team[i] = new PlayerControlBlock{};
        batting_team[i] = new PlayerControlBlock{};

        fielding_team[i]->player_id = i;
        fielding_team[i]->thread_id = static_cast<pthread_t>(0);
        fielding_team[i]->is_active_on_pitch = false;
        fielding_team[i]->is_waiting_in_pavilion = false;
        fielding_team[i]->expected_stay_duration = 0;
        fielding_team[i]->deliveries_bowled = 0;
        fielding_team[i]->last_ball_faced = -1;
        fielding_team[i]->arrival_time = 0.0;
        fielding_team[i]->dispatch_time = 0.0;
        fielding_team[i]->priority_score = 0;
        fielding_team[i]->is_death_over_specialist = false;

        if (i == 0) {
            fielding_team[i]->role = PlayerRole::WICKETKEEPER;
            fielding_team[i]->is_active_on_pitch = true;
        } else if (i <= BOWLER_POOL_SIZE) {
            fielding_team[i]->role = PlayerRole::BOWLER;
            bowler_pool[bowler_pool_size++] = fielding_team[i];
        } else {
            fielding_team[i]->role = PlayerRole::FIELDER;
            fielding_team[i]->is_active_on_pitch = true;
        }

        batting_team[i]->player_id = i;
        batting_team[i]->thread_id = static_cast<pthread_t>(0);
        batting_team[i]->role = PlayerRole::BATSMAN;
        batting_team[i]->is_active_on_pitch = false;
        batting_team[i]->is_waiting_in_pavilion = true;
        batting_team[i]->expected_stay_duration = TEAM_SIZE - i;
        batting_team[i]->deliveries_bowled = 0;
        batting_team[i]->last_ball_faced = -1;
        batting_team[i]->arrival_time = 0.0;
        batting_team[i]->dispatch_time = 0.0;
        batting_team[i]->priority_score = 1;
        batting_team[i]->is_death_over_specialist = false;
    }

    // Roster index 8 (1-based) is designated as the death-over specialist.
    batting_team[7]->is_death_over_specialist = true;
    batting_team[7]->priority_score = 100;

    if (bowler_pool_size > 0) {
        current_bowler_index = 0;
        current_bowler_pcb = bowler_pool[current_bowler_index];
        if (current_bowler_pcb != nullptr) {
            current_bowler_pcb->is_active_on_pitch = true;
        }
    }

    {
        const int rc = pthread_create(&umpire_thread, nullptr, umpire_routine, nullptr);
        if (rc != 0) {
            errno = rc;
            perror("pthread_create(umpire_routine) failed");
            goto cleanup;
        }
    }

    {
        const int rc = pthread_create(&bowler_manager_thread, nullptr, bowler_manager_routine, nullptr);
        if (rc != 0) {
            errno = rc;
            perror("pthread_create(bowler_manager_routine) failed");
            goto cleanup;
        }
    }

    for (int i = 0; i < TEAM_SIZE; ++i) {
        void* (*entry)(void*) = nullptr;
        if (fielding_team[i]->role == PlayerRole::BOWLER) {
            if (fielding_team[i] != current_bowler_pcb) {
                continue;
            }
            entry = bowler_routine;
        } else {
            entry = fielder_routine;
        }

        fielding_team[i]->is_active_on_pitch = true;

        const int rc = pthread_create(&fielding_team[i]->thread_id, nullptr, entry, fielding_team[i]);
        if (rc != 0) {
            errno = rc;
            perror("pthread_create(fielding thread) failed");
            match_completed = true;
            goto join_and_cleanup;
        }
    }

    for (int i = 0; i < 2; ++i) {
        if (sem_wait(&crease_semaphore) != 0) {
            perror("sem_wait(crease_semaphore) failed");
            match_completed = true;
            goto join_and_cleanup;
        }

        batting_team[i]->is_active_on_pitch = true;
        batting_team[i]->is_waiting_in_pavilion = false;

        const int rc = pthread_create(&batting_team[i]->thread_id, nullptr, batsman_routine, batting_team[i]);
        if (rc != 0) {
            errno = rc;
            perror("pthread_create(initial batsman) failed");
            sem_post(&crease_semaphore);
            match_completed = true;
            goto join_and_cleanup;
        }

        ++active_batsmen_count;
    }

    active_striker_pcb = batting_team[0];
    active_non_striker_pcb = batting_team[1];
    active_striker_id = batting_team[0]->player_id;
    non_striker_id = batting_team[1]->player_id;

    for (int i = 2; i < TEAM_SIZE; ++i) {
        batting_team[i]->arrival_time = get_timestamp();
        pavilion_queue[pavilion_size++] = batting_team[i];
    }
    SortPavilionBySJF();

join_and_cleanup:
    if (umpire_thread != static_cast<pthread_t>(0)) {
        pthread_join(umpire_thread, nullptr);
    }

    match_completed = true;
    pthread_cond_broadcast(&bowler_manager_cond);
    pthread_cond_broadcast(&fielders_cond);
    pthread_cond_broadcast(&keeper_cond);
    pthread_cond_broadcast(&batsman_cond);

    if (bowler_manager_thread != static_cast<pthread_t>(0)) {
        pthread_join(bowler_manager_thread, nullptr);
    }

    for (int i = 0; i < TEAM_SIZE; ++i) {
        if (fielding_team[i] != nullptr && fielding_team[i]->thread_id != static_cast<pthread_t>(0)) {
            pthread_cancel(fielding_team[i]->thread_id);
            pthread_join(fielding_team[i]->thread_id, nullptr);
        }
    }

    for (int i = 0; i < TEAM_SIZE; ++i) {
        if (batting_team[i] != nullptr && batting_team[i]->thread_id != static_cast<pthread_t>(0)) {
            pthread_cancel(batting_team[i]->thread_id);
            pthread_join(batting_team[i]->thread_id, nullptr);
        }
    }

    if (pthread_mutex_lock(&log_mutex) == 0) {
        std::printf("\n========== FINAL SCORECARD ==========\n");
        std::printf("Final Score: %d\n", g_match_context.global_score);
        std::printf("Wickets: %d\n", g_match_context.total_wickets);
        std::printf("Overs Bowled: %d.%d\n", g_match_context.current_over, g_match_context.balls_in_current_over);
        std::printf("=====================================\n");
        std::fflush(stdout);
        pthread_mutex_unlock(&log_mutex);
    }

    {
        std::unordered_set<PlayerControlBlock*> freed;
        auto delete_once = [&freed](PlayerControlBlock*& pcb) {
            if (pcb != nullptr && freed.insert(pcb).second) {
                delete pcb;
            }
            pcb = nullptr;
        };

        for (int i = 0; i < TEAM_SIZE; ++i) {
            delete_once(fielding_team[i]);
        }

        for (int i = 0; i < TEAM_SIZE; ++i) {
            delete_once(batting_team[i]);
        }

        delete_once(active_striker_pcb);
        delete_once(active_non_striker_pcb);

        for (int i = 0; i < TEAM_SIZE; ++i) {
            delete_once(pavilion_queue[i]);
        }

        for (int i = 0; i < BOWLER_POOL_SIZE; ++i) {
            delete_once(bowler_pool[i]);
        }
    }

cleanup:
    if (gantt_log_file.is_open()) {
        gantt_log_file.flush();
        gantt_log_file.close();
    }
    if (wait_time_log_file.is_open()) {
        wait_time_log_file.flush();
        wait_time_log_file.close();
    }
    if (crease_semaphore_ready) {
        sem_destroy(&crease_semaphore);
    }
    if (bowler_manager_cond_ready) {
        pthread_cond_destroy(&bowler_manager_cond);
    }
    if (run_exchange_cond_ready) {
        pthread_cond_destroy(&run_exchange_cond);
    }
    if (batsman_cond_ready) {
        pthread_cond_destroy(&batsman_cond);
    }
    if (umpire_cond_ready) {
        pthread_cond_destroy(&umpire_cond);
    }
    if (keeper_cond_ready) {
        pthread_cond_destroy(&keeper_cond);
    }
    if (fielders_cond_ready) {
        pthread_cond_destroy(&fielders_cond);
    }
    if (log_mutex_ready) {
        pthread_mutex_destroy(&log_mutex);
    }
    if (file_mutex_ready) {
        pthread_mutex_destroy(&file_mutex);
    }
    if (ball_mutex_ready) {
        pthread_mutex_destroy(&ball_mutex);
    }
    if (end2_mutex_ready) {
        pthread_mutex_destroy(&end2_mutex);
    }
    if (end1_mutex_ready) {
        pthread_mutex_destroy(&end1_mutex);
    }
    if (score_mutex_ready) {
        pthread_mutex_destroy(&score_mutex);
    }

    return EXIT_SUCCESS;
}
